# PostgreSQL — required for saving leads, dashboard, CRM, auth
DATABASE_URL="postgresql://user:password@localhost:5432/obsidian_prospect_engine?schema=public"

# Session signing — required for login (min 32 characters)
SESSION_SECRET="generate-a-long-random-string-at-least-32-chars"

# Public app URL — used in invite emails (set to your Vercel domain)
APP_URL="https://your-app.vercel.app"

# Google Places API (New) + Geocoding — required for lead search
GOOGLE_PLACES_API_KEY="your-google-api-key"

# Resend — required for team invite emails
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM_EMAIL="Obsidian Prospect Engine <onboarding@obsidian-systems.tech>"

# Optional — set to pin super admin password on seed; otherwise random
ADMIN_INITIAL_PASSWORD=""

# Optional — future AI outreach drafts
OPENAI_API_KEY=""

# Optional — future SMS integrations
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
